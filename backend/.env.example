# ---- General ----
ENVIRONMENT=development
DEBUG=true

# ---- Security ----
SECRET_KEY=replace-with-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- Database ----
POSTGRES_USER=goldpx
POSTGRES_PASSWORD=goldpx
POSTGRES_DB=goldpx
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- CORS (comma-separated origins, or * for all) ----
BACKEND_CORS_ORIGINS=["*"]

# ---- File storage ----
# local | cloudinary | s3  (only "local" works until keys below are filled in)
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=15

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=

# ---- Notifications ----
# No WhatsApp Business API key yet -> wa.me deep links are generated instead
WHATSAPP_BUSINESS_NUMBER=923145355656

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@goldpx.com
SMTP_FROM_NAME=GOLD Px

SMS_PROVIDER_ENABLED=false
SMS_API_KEY=
SMS_API_SECRET=

# ---- First super admin (created by scripts/seed_data.py) ----
FIRST_SUPERADMIN_EMAIL=admin@goldpx.com
